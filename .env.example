# ═══════════════════════════════════════════════════════
# OI HUNTER V2.0 - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real API keys and passwords in .env
# 3. NEVER commit .env to Git!
#
# ═══════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application port
APP_PORT=8000


# ═══════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ═══════════════════════════════════════════════════════

# Full connection string
DATABASE_URL=postgresql://oihunter:your_secure_password_here@localhost:5432/oihunter

# Or individual components (if needed):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=oihunter
POSTGRES_USER=oihunter
POSTGRES_PASSWORD=your_secure_password_here


# ═══════════════════════════════════════════════════════
# REDIS (Caching)
# ═══════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0


# ═══════════════════════════════════════════════════════
# MEXC API (Primary Exchange)
# ═══════════════════════════════════════════════════════

# Get your keys from: https://www.mexc.com/user/openapi
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here

# Rate limits (requests per second)
MEXC_RATE_LIMIT=20


# ═══════════════════════════════════════════════════════
# BINANCE API (Backup Exchange - Optional)
# ═══════════════════════════════════════════════════════

# Get your keys from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_RATE_LIMIT=20


# ═══════════════════════════════════════════════════════
# COINGECKO API (Market Cap Data)
# ═══════════════════════════════════════════════════════

# Free tier: no key needed (10-30 requests/min)
# Pro tier: get key from https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
COINGECKO_RATE_LIMIT=10


# ═══════════════════════════════════════════════════════
# TELEGRAM BOT
# ═══════════════════════════════════════════════════════

# Create bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID (to receive signals)
# Get it from @userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ═══════════════════════════════════════════════════════
# TRADING PARAMETERS
# ═══════════════════════════════════════════════════════

# Minimum signal score to send (0-10)
MIN_SIGNAL_SCORE=7.0

# Maximum position size (% of capital)
MAX_POSITION_SIZE=8.0

# Default stop loss percentage
DEFAULT_STOP_LOSS_PCT=4.0

# Enable SHORT signals (true/false)
ENABLE_SHORT_SIGNALS=true

# Token focus: all, low_cap, mid_cap, high_cap
TOKEN_FOCUS=low_cap

# Low-cap threshold (market cap in USD)
LOW_CAP_THRESHOLD=100000000


# ═══════════════════════════════════════════════════════
# APPROACH D (HYBRID) - WebSocket Settings
# ═══════════════════════════════════════════════════════

# Enable WebSocket real-time stream
ENABLE_WEBSOCKET=true

# Priority scanning intervals (seconds)
CRITICAL_SCAN_INTERVAL=15
HIGH_SCAN_INTERVAL=30
MEDIUM_SCAN_INTERVAL=60
LOW_SCAN_INTERVAL=180

# Batch update interval (seconds)
BATCH_UPDATE_INTERVAL=60


# ═══════════════════════════════════════════════════════
# BACKTESTING (Optional)
# ═══════════════════════════════════════════════════════

# Enable backtesting mode
BACKTESTING_MODE=false

# Initial capital for backtesting
BACKTESTING_CAPITAL=1000.0

# Slippage percentage
BACKTESTING_SLIPPAGE=0.1


# ═══════════════════════════════════════════════════════
# MONITORING & ALERTS (Optional)
# ═══════════════════════════════════════════════════════

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable performance monitoring
ENABLE_MONITORING=true
